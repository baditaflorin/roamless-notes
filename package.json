{
  "name": "roamless-notes",
  "private": false,
  "version": "0.1.0",
  "description": "Local-first outliner with backlinks, graph search, semantic recall, and portable state.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node scripts/prepare-pages.mjs && tsc -b && vite build && node scripts/postbuild.mjs",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "pages-preview": "vite preview --host 0.0.0.0",
    "preview": "vite preview",
    "smoke": "npm run build && playwright test --config playwright.config.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev45.0",
    "@huggingface/transformers": "^4.2.0",
    "@tanstack/react-query": "^5.100.9",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "lucide-react": "^1.14.0",
    "minisearch": "^7.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "yjs": "^13.6.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
